{
  "name": "NPSSurvey",
  "type": "object",
  "properties": {
    "organization_id": {
      "type": "string",
      "description": "The tenant (Organization) this survey belongs to"
    },
    "hotel_id": {
      "type": "string",
      "description": "ID of the hotel/branch"
    },
    "guest_name": {
      "type": "string"
    },
    "guest_email": {
      "type": "string"
    },
    "booking_id": {
      "type": "string"
    },
    "score": {
      "type": "number",
      "description": "0-10 NPS score"
    },
    "category": {
      "type": "string",
      "enum": [
        "detractor",
        "passive",
        "promoter"
      ]
    },
    "feedback": {
      "type": "string"
    },
    "room_number": {
      "type": "string"
    },
    "stay_date": {
      "type": "string",
      "format": "date"
    }
  },
  "required": [
    "guest_name",
    "guest_email",
    "score"
  ]
}