{
  "name": "Referral",
  "type": "object",
  "properties": {
    "organization_id": {
      "type": "string",
      "description": "The tenant (Organization) this referral belongs to"
    },
    "hotel_id": {
      "type": "string",
      "description": "ID of the hotel/branch"
    },
    "referrer_name": {
      "type": "string"
    },
    "referrer_email": {
      "type": "string"
    },
    "referral_code": {
      "type": "string"
    },
    "referred_name": {
      "type": "string"
    },
    "referred_email": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "converted",
        "rewarded"
      ],
      "default": "pending"
    },
    "reward_type": {
      "type": "string",
      "description": "e.g. 10% off, 500 loyalty pts"
    },
    "reward_given": {
      "type": "boolean",
      "default": false
    },
    "converted_at": {
      "type": "string"
    }
  },
  "required": [
    "referrer_name",
    "referrer_email",
    "referral_code"
  ]
}