{
  "name": "Announcement",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "priority": {
      "type": "string",
      "enum": [
        "normal",
        "important",
        "urgent"
      ],
      "default": "normal"
    },
    "target_roles": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "posted_by": {
      "type": "string"
    },
    "expires_at": {
      "type": "string",
      "format": "date"
    },
    "pinned": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "title",
    "content"
  ]
}